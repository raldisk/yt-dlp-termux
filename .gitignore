# yt-dlp-termux .gitignore

# Personal config — never commit
config/user.conf

# Generated checksum (regenerated on each install)
install.sh.sha256

# yt-dlp runtime artifacts
*.part
*.ytdl
*.temp.*

# Cookie files
cookies/
*.cookies.txt

# Logs
*.log

# macOS
.DS_Store

# Editors
.vscode/
*.swp
*~
